# Database (Postgres — e.g. Vercel Postgres, Supabase, Neon)
# Supabase 기준: 런타임(DATABASE_URL)은 트랜잭션 모드 풀러(포트 6543, ?pgbouncer=true 필수) —
# 서버리스에서 동시 연결이 늘어나도 커넥션이 고갈되지 않는다.
DATABASE_URL="postgresql://user:password@host:6543/uxui_job?pgbouncer=true&connection_limit=1"
# db push/migrate 같은 DDL 전용. 트랜잭션 모드는 DDL을 지원하지 않아 세션 모드(포트 5432)로 직접 붙는다.
DIRECT_URL="postgresql://user:password@host:5432/uxui_job"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # openssl rand -base64 32

# Google Gemini (JD 분석용, 무료 티어, https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# Resend (이메일 알림, https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="UXUI Job <onboarding@resend.dev>"

# Vercel Cron이 /api/cron/fetch-jobs를 호출할 때 Authorization: Bearer 헤더로 자동 전송하는 값.
# Vercel 프로젝트 환경 변수에도 동일한 값을 등록해야 한다. openssl rand -base64 32
CRON_SECRET=""

# Mixpanel (프로덕트 분석, https://mixpanel.com). Project Settings > Access Keys > Project Token.
# 브라우저에서 직접 이벤트를 전송하는 클라이언트 SDK라 NEXT_PUBLIC_ 접두사가 필요하다.
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# Google Analytics 4 (https://analytics.google.com). 데이터 스트림의 측정 ID(G-로 시작).
# gtag.js도 브라우저에서 직접 로드되는 클라이언트 값이라 NEXT_PUBLIC_ 접두사가 필요하다.
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
