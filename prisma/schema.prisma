generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 런타임 쿼리는 트랜잭션 모드 풀러(pgbouncer)로 — 서버리스 환경에서 동시 연결이 늘어나도
  // 커넥션이 고갈되지 않는다. 세션 모드(5432)는 동시 연결 제한이 낮아 실제 배포 트래픽에서
  // "max clients reached" 에러가 날 수 있다.
  url       = env("DATABASE_URL")
  // db push/migrate 같은 DDL은 트랜잭션 모드가 지원하지 않아 세션 모드로 직접 붙는다.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime   @default(now())
  accounts      Account[]
  sessions      Session[]
  preference    Preference?
  savedJobs     SavedJob[]
  follows       Follow[]
  notifications Notification[]
  jobFeedback   JobFeedback[]
  externalJobSaves ExternalJobSave[]
  serviceFeedback ServiceFeedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 온보딩에서 선택한 관심 직무/플랫폼/산업/목표 스테이지 및 이메일 알림 수신 여부
model Preference {
  id          String   @id @default(cuid())
  userId      String   @unique
  roles       String[]
  platforms   String[]
  industries  String[]
  stages      String[]
  emailOptIn  Boolean  @default(false)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 기업 프로필 페이지(/companies/:id)의 정보 소스. Job.companyName은 카드 표시용으로 계속 남겨두되,
// 기업 단위 정보(사원수/설립/본사 위치 등)는 여기서만 관리한다.
model Company {
  id            String    @id @default(cuid())
  name          String    @unique
  logo          String?
  // "산업" 필터와 동일한 값 집합을 재사용
  industry      String
  // "규모" 필터와 동일한 값 집합을 재사용 (스타트업/유니콘/중견 기업/대기업/에이전시)
  stage         String
  // 아래 세 항목은 자동 수집 소스가 없어 당장은 비어있을 수 있다. 값이 있을 때만 프로필에 노출.
  employeeCount String?
  founded       String?
  headquarters  String?
  createdAt     DateTime  @default(now())
  jobs          Job[]
  follows       Follow[]
}

model Job {
  id          String       @id @default(cuid())
  title       String
  companyName String
  companyLogo String?
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id])
  role        String
  platforms   String[]
  industry    String
  stage       String
  location    String?
  description String       @db.Text
  applyUrl    String       @unique
  // 공고 원문에서 추출한 서류접수 기간 텍스트(참고용 원문). 명시된 기간이 없으면 "상시채용".
  applicationPeriod String @default("상시채용")
  // 위 텍스트에서 파싱한 실제 마감일. 상시채용이면 null. D-day 계산에 사용.
  applicationDeadline DateTime?
  // 공고 원문에서 추출. 명시되지 않으면 각각 "정규직" / "경력무관"으로 기본 처리.
  employmentType    String @default("정규직")
  experienceLevel   String @default("경력무관")
  postedAt    DateTime     @default(now())
  // 마감 1개월 경과 시 자동 세팅되는 소프트 삭제 마커. null이면 노출 대상.
  archivedAt  DateTime?
  savedBy     SavedJob[]
  analysis    JobAnalysis?
  feedback    JobFeedback[]
}

// 공고 상세페이지 진입 시 실행되는 AI 분석 결과 캐시 (재실행 방지)
model JobAnalysis {
  id           String   @id @default(cuid())
  jobId        String   @unique
  coreKeywords String[]
  resumeTip    String   @db.Text
  // 공고 목록 카드에 보여줄, 이 직무가 주로 하는 업무를 나타내는 단어 (최대 4개)
  taskKeywords String[]
  createdAt    DateTime @default(now())
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// "AI 분석" 섹션 하단 피드백 위젯 제출 기록. 유저당 공고 1건에 1개만 남길 수 있으며
// (제출 후에는 위젯이 완료 상태로 고정되고 재제출 불가), 로그인 유저만 제출 가능하다.
model JobFeedback {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  helpful   Boolean
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

// 유저가 마이페이지에서 외부(우리 DB에 없는) 채용공고 링크를 붙여넣어 저장한 기록.
// Job과 달리 여러 유저가 공유하는 공개 리스팅이 아니라 유저 개인 소유의 스냅샷이라,
// SavedJob처럼 Job을 참조하지 않고 원문 텍스트/분석 결과를 이 레코드 안에 통째로 저장한다.
model ExternalJobSave {
  id           String   @id @default(cuid())
  userId       String
  sourceUrl    String
  title        String
  companyName  String
  description  String   @db.Text
  coreKeywords String[]
  resumeTip    String   @db.Text
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// GNB "서비스 의견" 탭에서 남기는 자유 의견. JobFeedback과 달리 특정 공고에 묶이지 않고,
// 유저당 여러 건 남길 수 있다. 별도 조회 UI 없이 관리자가 DB에서 직접 확인하는 용도.
model ServiceFeedback {
  id        String   @id @default(cuid())
  // 로그인 없이도 남길 수 있어 null 허용 (비로그인 제출은 작성자 없이 저장됨).
  userId    String?
  category  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// 유저가 팔로우한 기업. 팔로우한 기업이 새 공고를 올리면 Notification이 생성된다.
model Follow {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

// 팔로우한 기업의 신규 공고 알림. 기업명/공고 제목은 나중에 기업명이 바뀌거나 공고가
// 소프트 삭제되어도 알림 히스토리 문구가 깨지지 않도록 발송 시점 값을 스냅샷으로 저장한다.
model Notification {
  id          String   @id @default(cuid())
  userId      String
  companyId   String
  companyName String
  // 공고 1건짜리 알림이면 그 공고 상세로, 여러 건을 묶은 알림이면 기업 프로필로 이동(jobId는 null).
  jobId       String?
  jobTitle    String?
  count       Int      @default(1)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
